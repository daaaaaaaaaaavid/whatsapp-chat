# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=whachat-support@googlegroups.com

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional: custom Hebrew invite emails (free tier ~100/day). If unset, uses Supabase Auth invite emails.
RESEND_API_KEY=
# Verified sender, e.g. WhaChat <invites@yourdomain.com>. Defaults to Resend onboarding sender.
RESEND_FROM_EMAIL=

# Cron (Vercel)
CRON_SECRET=

# Optional WebRTC TURN (prefer short-lived server credentials in production)
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
