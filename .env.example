# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=whachat-support@googlegroups.com

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Recommended: Hebrew invite emails via Resend (free ~100/day, ~3000/month).
# Without this, Supabase built-in mail is limited to ~2 emails/hour and English templates.
# 1) https://resend.com → API Key
# 2) Set RESEND_API_KEY in Vercel/local .env
# 3) Optional: verify your domain, then set RESEND_FROM_EMAIL=WhaChat <invites@yourdomain.com>
#    Until then, onboarding@resend.dev only delivers to your Resend account email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cron (Vercel)
CRON_SECRET=

# Optional WebRTC TURN (prefer short-lived server credentials in production)
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
