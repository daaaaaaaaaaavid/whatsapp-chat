# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=whachat-support@googlegroups.com

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Cron (Vercel)
CRON_SECRET=

# Optional WebRTC TURN (server-only — never put credentials in NEXT_PUBLIC_*)
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# Prefer coturn static-auth-secret (time-limited creds via /api/webrtc/ice):
TURN_URLS=
TURN_AUTH_SECRET=
# Fallback static creds (still server-only):
TURN_USERNAME=
TURN_CREDENTIAL=

# LiveKit (group meetings — free account at https://cloud.livekit.io)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional shared rate limit (Upstash Redis REST) — recommended on Vercel
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
